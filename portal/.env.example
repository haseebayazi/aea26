APP_NAME="CUI Alumni Excellence Awards 2026"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com/alumni

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ── Database (MySQL for production) ──────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cpanel_username_aea26
DB_USERNAME=cpanel_username_aea26
DB_PASSWORD=your_secure_password

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Cache ─────────────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

# ── Mail (optional — for password reset notifications) ───────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mail.your-domain.com
MAIL_PORT=587
MAIL_USERNAME=no-reply@your-domain.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@your-domain.com"
MAIL_FROM_NAME="CUI Alumni Excellence Awards"

# ── DomPDF ────────────────────────────────────────────────────────────────────
DOMPDF_ENABLE_REMOTE=false
DOMPDF_PAPER_SIZE=A4
